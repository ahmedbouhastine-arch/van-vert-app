rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    //-------------------------------------------------------------------------
    // Helper Functions
    //-------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      let role = getUserRole();
      return role in ['admin', 'head-admin'];
    }
    
    function isReviewer() {
      let role = getUserRole();
      return role in ['admin', 'head-admin', 'reviewer'];
    }

    //-------------------------------------------------------------------------
    // Collection: users
    //-------------------------------------------------------------------------
    match /users/{userId} {
      // Any signed in user can view a user's profile (needed for admins to see applicant names).
      allow get: if isSignedIn();
      // Only reviewers and admins can list all users.
      allow list: if isReviewer();
      // A user can create their own user document.
      allow create: if isOwner(userId);
      // A user can update their own profile; an admin can update any user's profile (e.g., to change a role).
      allow update: if isOwner(userId) || isAdmin();
      // Only admins can delete user documents.
      allow delete: if isAdmin();
    }

    //-------------------------------------------------------------------------
    // Collection: applications
    //-------------------------------------------------------------------------
    match /applications/{applicationId} {
      
      function isApplicationOwner() {
        return resource.data.userId == request.auth.uid;
      }
      
      function isCreatingOwnApplication() {
        return request.resource.data.userId == request.auth.uid;
      }
      
      function isApplicationUpdateValid() {
        // Core data like the owner ID should not change after creation.
        return request.resource.data.userId == resource.data.userId;
      }

      // Users can get their own applications. Reviewers/Admins can get any application.
      allow get: if isSignedIn() && (isApplicationOwner() || isReviewer());
      
      // Any signed-in user can attempt to list applications.
      // Security is enforced by the 'get' rule, which Firestore checks for each document in the result.
      // This means users will only be able to list applications they have 'get' access to.
      allow list: if isSignedIn();
      
      // Users can create an application for themselves.
      allow create: if isSignedIn() && isCreatingOwnApplication();
      
      // Users can update their own application only if it's still a draft.
      // Reviewers/Admins can update any application at any stage.
      // The application's owner must not change.
      allow update: if isSignedIn() && isApplicationUpdateValid() && (
        (isApplicationOwner() && resource.data.status == 'draft') || isReviewer()
      );
      
      // For data integrity, only a Head Admin can delete an application record.
      allow delete: if isSignedIn() && getUserRole() == 'head-admin';
    }
  }
}
