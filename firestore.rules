/**
 * Core Philosophy: This ruleset enforces a strict user-ownership model. All user-related data,
 * including applications and documents, is stored in subcollections under that user's unique
 * document. This path-based security model ensures that users can only ever access their own data tree.
 *
 * Data Structure: The data is organized hierarchically to reflect ownership:
 * - /users/{userId} - The root document for a user's profile.
 * - /users/{userId}/applications/{applicationId} - A subcollection of a user's license applications.
 * - /users/{userId}/applications/{applicationId}/documents/{documentId} - Documents related to a specific application.
 *
 * Key Security Decisions:
 * - User Isolation: A user's access is strictly confined to documents within their own `/users/{userId}` path. There is no cross-user data visibility.
 * - No Global Access: There are no "admin" or "public" roles defined in this ruleset. All access is predicated on matching the authenticated user's ID with the {userId} in the path.
 * - User Enumeration Disabled: Listing the top-level `/users` collection is explicitly forbidden to prevent attackers from scraping user profile information.
 * - Relational Integrity: On document creation, rules validate that internal ID fields (e.g., `data.userId`) match the IDs in the document path, ensuring data consistency. These fields are then enforced as immutable on update.
 *
 * Denormalization for Authorization: This ruleset relies on a path-based security model, which is a form of structural denormalization. The user's ID is part of the path for all their associated data, which eliminates the need for expensive cross-collection `get()` calls in security rules, resulting in a more performant and secure system.
 *
 * Structural Segregation: The entire data model is segregated by user at the root level, making it impossible for a query to accidentally leak data from another user.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    //-------------------------------------------------------------------------
    // Helper Functions
    //-------------------------------------------------------------------------

    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the authenticated user's UID matches the document's owner ID.
     * This is the primary function for enforcing the ownership model.
     * @param userId The unique identifier of the user to check against.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Confirms that a document exists before an update or delete operation.
     * This prevents unauthorized state changes on non-existent documents.
     */
    function docExists() {
      return resource != null;
    }

    /**
     * Validates that the User document's internal `id` field matches the
     * document ID from the path on creation.
     */
    function isValidUserCreate(userId) {
      return request.resource.data.id == userId;
    }

    /**
     * Enforces immutability of the User's `id` field on update.
     */
    function isUserUpdateValid() {
      return request.resource.data.id == resource.data.id;
    }

    /**
     * Validates that the Application document's internal fields (`userId`, `id`)
     * match the IDs from the document path on creation.
     */
    function isValidApplicationCreate(userId, applicationId) {
      let data = request.resource.data;
      return data.userId == userId && data.id == applicationId;
    }

    /**
     * Enforces immutability of an Application's relational IDs (`userId`, `id`) on update.
     */
    function isApplicationUpdateValid() {
      let data = request.resource.data;
      return data.userId == resource.data.userId && data.id == resource.data.id;
    }

    /**
     * Validates that the Document's internal fields (`applicationId`, `id`)
     * match the IDs from the document path on creation.
     */
    function isValidDocumentCreate(applicationId, documentId) {
      let data = request.resource.data;
      return data.applicationId == applicationId && data.id == documentId;
    }

    /**
     * Enforces immutability of a Document's relational IDs (`applicationId`, `id`) on update.
     */
    function isDocumentUpdateValid() {
      let data = request.resource.data;
      return data.applicationId == resource.data.applicationId && data.id == resource.data.id;
    }

    //-------------------------------------------------------------------------
    // Collection: users
    //-------------------------------------------------------------------------

    /**
     * @description Controls access to user profile documents.
     * @path /users/{userId}
     * @allow (create) An authenticated user creating their own user document. auth.uid must match {userId}.
     * @allow (get, update, delete) The user who owns the document. auth.uid must match {userId}.
     * @deny (list) Any user, to prevent user enumeration.
     * @deny (create, update) Any user trying to modify a document that is not their own.
     * @principle Restricts access to a user's own data tree and allows self-creation of the root user document.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && isValidUserCreate(userId);
      allow update: if isOwner(userId) && docExists() && isUserUpdateValid();
      allow delete: if isOwner(userId) && docExists();

      //-----------------------------------------------------------------------
      // Subcollection: applications
      //-----------------------------------------------------------------------

      /**
       * @description Controls access to a user's application subcollection.
       * @path /users/{userId}/applications/{applicationId}
       * @allow (create, get, list, update, delete) The user who owns the application. auth.uid must match {userId}.
       * @deny Any user trying to access applications they do not own.
       * @principle Enforces path-based ownership, ensuring a user can only manage their own applications.
       */
      match /applications/{applicationId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidApplicationCreate(userId, applicationId);
        allow update: if isOwner(userId) && docExists() && isApplicationUpdateValid();
        allow delete: if isOwner(userId) && docExists();

        //---------------------------------------------------------------------
        // Subcollection: documents
        //---------------------------------------------------------------------

        /**
         * @description Controls access to documents within a user's application.
         * @path /users/{userId}/applications/{applicationId}/documents/{documentId}
         * @allow (create, get, list, update, delete) The user who owns the parent application. auth.uid must match {userId}.
         * @deny Any user trying to access documents in an application they do not own.
         * @principle Inherits ownership from the parent path, ensuring document access is tied to application ownership.
         */
        match /documents/{documentId} {
          allow get: if isOwner(userId);
          allow list: if isOwner(userId);
          allow create: if isOwner(userId) && isValidDocumentCreate(applicationId, documentId);
          allow update: if isOwner(userId) && docExists() && isDocumentUpdateValid();
          allow delete: if isOwner(userId) && docExists();
        }
      }
    }
  }
}