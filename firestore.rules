
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    //-------------------------------------------------------------------------
    // Helper Functions
    //-------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function getUserRole() {
      // Safely access role from the user's document.
      // Assumes a /users/{uid} document exists for every authenticated user.
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isReviewer() {
      let role = getUserRole();
      return role in ['reviewer', 'admin', 'head-admin'];
    }
    
    function isAdmin() {
      let role = getUserRole();
      return role in ['admin', 'head-admin'];
    }
    
    function isHeadAdmin() {
      return getUserRole() == 'head-admin';
    }


    //-------------------------------------------------------------------------
    // Collection: users
    //-------------------------------------------------------------------------
    match /users/{userId} {
      // A user can create their own user document.
      allow create: if isOwner(userId);
      // Anyone signed in can view a user profile (needed for admins to see names on applications).
      allow get: if isSignedIn();
      // Only reviewers and above can list all users.
      allow list: if isReviewer();
      // An owner can update their own profile, an admin can update anyone's.
      allow update: if isOwner(userId) || isAdmin();
      // Only admins can delete user documents.
      allow delete: if isAdmin();
    }

    //-------------------------------------------------------------------------
    // Collection: applications
    //-------------------------------------------------------------------------
    match /applications/{applicationId} {
      
      function isApplicationOwner() {
        // Check the userId field in the document being accessed
        return resource.data.userId == request.auth.uid;
      }
      
      function isCreatingOwnApplication() {
        // Check the userId field in the document being created
        return request.resource.data.userId == request.auth.uid;
      }
      
      function isApplicationUpdateValid() {
        // Ensure the owner ID does not change after creation.
        return request.resource.data.userId == resource.data.userId;
      }

      // GET: A user can get their own application. Reviewers/Admins can get any application.
      allow get: if isSignedIn() && (isApplicationOwner() || isReviewer());
      
      // LIST: This is the key rule. Any signed-in user can attempt to list applications.
      // However, Firestore enforces the 'get' rule on each document in the result set.
      // This means a 'user' can only successfully list applications if their query is
      // constrained (e.g., where("userId", "==", auth.uid)), because the 'get' rule will
      // only pass for documents they own. An unconstrained query by a 'user' will fail.
      // A 'reviewer' or 'admin' will succeed because the `isReviewer()` part of the 'get'
      // rule will pass for all documents.
      allow list: if isSignedIn();
      
      // CREATE: Users can create an application for themselves.
      allow create: if isSignedIn() && isCreatingOwnApplication();
      
      // UPDATE: Users can update their own application only if it's still a draft.
      // Reviewers/Admins can update any application at any stage.
      allow update: if isSignedIn() && isApplicationUpdateValid() && (
        (isApplicationOwner() && resource.data.status == 'draft') || isReviewer()
      );
      
      // DELETE: For data integrity, only a Head Admin can delete an application record.
      allow delete: if isHeadAdmin();
    }
  }
}
