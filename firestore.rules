rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    //-------------------------------------------------------------------------
    // Helper Functions
    //-------------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function getUserRole(uid) {
      // Safely access role from the user's document.
      return get(/databases/$(database)/documents/users/$(uid)).data.role;
    }

    function isReviewer() {
      let role = getUserRole(request.auth.uid);
      return role in ['reviewer', 'admin', 'head-admin'];
    }
    
    function isAdmin() {
      let role = getUserRole(request.auth.uid);
      return role in ['admin', 'head-admin'];
    }
    
    function isHeadAdmin() {
      return getUserRole(request.auth.uid) == 'head-admin';
    }


    //-------------------------------------------------------------------------
    // Collection: users
    //-------------------------------------------------------------------------
    match /users/{userId} {
      // A user can create their own user document during sign-up.
      allow create: if isOwner(userId);
      
      // An owner can read their own profile. A reviewer (and above) can read any profile.
      allow get: if isOwner(userId) || isReviewer();
      
      // Only reviewers and above can list all users.
      allow list: if isReviewer();
      
      // - An owner can update their own profile, but cannot change their role.
      // - A head-admin can update any user's profile and role.
      // - An admin can update any user's profile, but cannot edit a head-admin or change any roles.
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role) ||
                     isHeadAdmin() ||
                     (isAdmin() && resource.data.role != 'head-admin' && request.resource.data.role == resource.data.role);
      
      // Only head admins can delete user documents.
      allow delete: if isHeadAdmin();

      // Subcollection: notifications
      match /notifications/{notificationId} {
        // A user can read, list, update (mark as read), and delete their own notifications.
        allow list, get, update, delete: if isOwner(userId);
        
        // Only admins can create notifications for users (e.g., when an application status changes).
        allow create: if isAdmin();
      }
    }

    //-------------------------------------------------------------------------
    // Collection: applications
    //-------------------------------------------------------------------------
    match /applications/{applicationId} {
      
      function isApplicationOwner() {
        // Check the userId field in the document being accessed
        return resource.data.userId == request.auth.uid;
      }
      
      function isCreatingOwnApplication() {
        // Check the userId field in the document being created
        return request.resource.data.userId == request.auth.uid;
      }
      
      function isApplicationUpdateValid(requestData, resourceData) {
        // Ensure the owner ID and creation timestamp do not change.
        return requestData.userId == resourceData.userId &&
               requestData.createdAt == resourceData.createdAt;
      }

      // READ: Anyone who is signed in can read any application data.
      allow read: if isSignedIn();
      
      // CREATE: Users can create an application for themselves.
      allow create: if isSignedIn() && isCreatingOwnApplication();
      
      // UPDATE:
      // - An owner can update their own application only if it's a draft.
      // - A reviewer (or above) can update any application at any stage.
      allow update: if isSignedIn() && isApplicationUpdateValid(request.resource.data, resource.data) && (
        (isApplicationOwner() && resource.data.status == 'draft') || isReviewer()
      );
      
      // DELETE: For data integrity, only a Head Admin can delete an application record.
      allow delete: if isHeadAdmin();
    }
  }
}
