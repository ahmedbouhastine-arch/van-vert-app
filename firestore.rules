
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Looks up the role stored on a user's profile document.
    function getUserRole(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isPrivileged(uid) {
      // reviewer or higher can read everything they need to do their job
      return getUserRole(uid) in ['reviewer', 'admin', 'head-admin'];
    }

    function isAdmin(uid) {
      // admin or higher can make case decisions (status/feedback/documents)
      return getUserRole(uid) in ['admin', 'head-admin'];
    }

    // --- User Profiles ---
    // Anyone signed in (non-anonymously, unless it's their own doc) can read a
    // profile — needed for names/avatars across applications & community.
    // Users create/update their own profile but cannot change their own role.
    // Head Admins can update any profile, including roles.
    match /users/{userId} {
      allow read: if isSignedIn() &&
                  (request.auth.token.firebase.sign_in_provider != 'anonymous' || request.auth.uid == userId);

      // Self-registration always uses role 'user', except for the seeded dev
      // test accounts (see src/lib/dev-test-accounts.ts) which register
      // directly into their designated role so each permission level can be
      // exercised locally without a head-admin promoting them by hand.
      allow create: if request.auth.uid == userId &&
                    (request.resource.data.role == 'user' ||
                     (request.resource.data.role == 'reviewer' && request.auth.token.email == '2@dev.va') ||
                     (request.resource.data.role == 'admin' && request.auth.token.email == '3@dev.va') ||
                     (request.resource.data.role == 'head-admin' && request.auth.token.email == '4@dev.va'));

      allow update: if (request.auth.uid == userId &&
                        (!('role' in resource.data) || request.resource.data.role == resource.data.role)) ||
                    getUserRole(request.auth.uid) == 'head-admin';

      allow delete: if false; // Profiles are never deleted directly (see account-deletion flow).

      // --- Notifications subcollection ---
      // Owners can read their notifications, mark them read, and clear them.
      // Reviewers/admins/head-admins can also create notifications for a user
      // (e.g. when they change that user's application status) — these writes
      // happen on the applicant's behalf, not the reviewer's own subcollection.
      match /notifications/{notificationId} {
        allow read, update, delete: if isSignedIn() && request.auth.uid == userId;
        allow create: if isSignedIn() &&
                      (request.auth.uid == userId || isPrivileged(request.auth.uid));
      }
    }

    // --- Applications ---
    match /applications/{applicationId} {

      function isOwner() {
        return request.auth.uid == resource.data.userId;
      }

      // Read: owners can see their own applications; reviewers and above can
      // see every application (needed for the review queue & analytics).
      allow read: if isSignedIn() && (isOwner() || isPrivileged(request.auth.uid));

      // Create: a user may only create an application for themselves.
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;

      // Update: owners may edit their own application while it's still a
      // draft (e.g. uploading documents, submitting). Admins/head-admins can
      // update any application at any stage (status, feedback, documents).
      allow update: if isSignedIn() &&
                    ((isOwner() && resource.data.status == 'draft') || isAdmin(request.auth.uid));

      // Delete: only the owner can remove their own application (e.g. a draft).
      allow delete: if isSignedIn() && isOwner();
    }
  }
}
