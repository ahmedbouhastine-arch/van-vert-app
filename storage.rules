rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    function isPrivileged() {
      // Role is read from the auth token's custom claims (synced whenever a
      // user's role changes) rather than via a Firestore lookup — the Storage
      // bucket and Firestore database live in different regions, and
      // cross-service get() calls across that distance reliably fail/timeout,
      // which Firebase rules treat as a denial.
      return request.auth.token.role in ['reviewer', 'admin', 'head-admin'];
    }

    // Rule for profile pictures: users can write to their own picture path.
    // Anonymous users can only read their own picture; registered users can read any picture.
    match /profile-pictures/{userId}/{allPaths=**} {
      allow read: if request.auth != null && (request.auth.token.firebase.sign_in_provider != 'anonymous' || request.auth.uid == userId);
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Rule for application documents. The owning user's ID is encoded directly
    // in the path so ownership can be checked without a cross-service Firestore
    // lookup (see isPrivileged for why those are unreliable here).
    match /applications/{userId}/{applicationId}/{allPaths=**} {
      allow read: if request.auth != null && (request.auth.uid == userId || isPrivileged());
      // Writes are handled by server-side actions which use service account credentials
      // and bypass these rules. Client-side writes are allowed if the user is the owner.
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}